// Reusable stat tile, imported by examples/demo.nowui via
// `# widgets/StatCard.nowui`. Kept generic (fixed label/value here, since
// `${var}` interpolation of layout params isn't wired up yet — see
// CLAUDE.md) purely to demonstrate that an imported layout's classes,
// transitions, and hover variants all work exactly as if defined locally.
layout: StatCard w-full bg-white border border-gray-200 rounded-lg p-5 gap-1
    transition duration-150 ease-out hover:scale-105 hover:border-blue-400 {
  Text `1,204` text-gray-800 font-semibold text-2xl
  Text `Active sessions` text-gray-500 text-sm
}
