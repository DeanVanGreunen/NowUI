// Full-feature showcase: every system component and style category added
// since the original login-screen reference, in one page. See CLAUDE.md for
// the exact vocabulary and the honest list of what's deliberately not
// supported (3D transforms, dark:/group-*/peer-*, filters/shadows, etc).
//
// Run:  cargo run -p nowui-runtime -- examples/demo.nowui App
//
// Covers: file imports (#), flexbox + grid layout, the color/spacing/
// typography scales, borders + per-corner radius, opacity, 2D transforms,
// hover:/active: transitions, position-relative/absolute, z-index paint
// layering, Checkbox, Dropdown (floating popup, doesn't push layout),
// scroll-v (styleable scrollbar, inverted/natural wheel direction).

layout: App w-[fill] h-[fill] bg-gray-100 {

  Bar row w-full items-center justify-between bg-gray-900 h-14 px-6 {
    Text `NowUI Dashboard` text-white font-semibold text-lg

    // position-relative + position-absolute: the "3" badge is pinned to its
    // own (relative) wrapper via top/right offsets and doesn't affect layout.
    Container position-relative w-[hug] h-[hug] {
      Text `Alerts` text-gray-300 text-sm font-medium
      Container position-absolute top-[-8px] right-[-14px] bg-red-500 text-white text-sm font-semibold rounded-full px-[7px] {
        Text `3`
      }
    }
  }

  Container w-[fill] h-[fill] items-center justify-center gap-6 p-8 scroll-v {

    // z-index demo: the blue card is authored FIRST but layered ON TOP via
    // z-index-20 vs. the white card's z-index-1 â€” paint order follows
    // z-index, not source order, for two position-absolute siblings sharing
    // the same (position-relative) containing block.
    Container position-relative w-[960px] h-[160px] {
      Card position-absolute top-[20px] left-[0px] w-[360px] h-[120px] bg-blue-100 border border-blue-400 rounded-lg p-4 z-index-20 {
        Text `Front card` text-blue-800 font-semibold
        Text `z-index-20 â€” painted last despite being authored first` text-blue-700 text-sm
      }
      Card position-absolute top-[0px] left-[220px] w-[360px] h-[120px] bg-white border border-gray-300 rounded-lg p-4 z-index-1 {
        Text `Back card` text-gray-700 font-semibold
        Text `z-index-1 â€” behind, even though authored second` text-gray-500 text-sm
      }
    }

    Container row w-[960px] gap-4 items-start {

      // Settings: Dropdown (styled border/radius; options float over the
      // page and don't push the button below it down) + a styled Checkbox
      // + a hover/active-transitioning button (scale + rotate + color).
      Card w-[fill] bg-white border border-gray-200 rounded-lg p-6 gap-3 {
        Text `Settings` text-gray-800 font-semibold text-lg pb-2

        Text `Theme` text-gray-700 text-sm font-medium
        Dropdown `Choose a theme` `Light` `Dark` `System` w-full border border-gray-300 rounded {value: state.theme}

        Checkbox `Enable notifications` text-gray-700 text-sm border border-gray-400 bg-gray-50 rounded pt-2

        // Slider: text-color is the track fill/thumb accent, border-color is
        // the track background â€” draggable with the mouse (real interaction,
        // not just decoration). `{value: 60}` is a literal starting position
        // (0..=100); a `state.*` path there would be used once reactivity
        // (roadmap step 6) can resolve it live instead.
        Text `Volume` text-gray-700 text-sm font-medium pt-2
        Slider w-full text-blue-600 border-gray-200 {value: 60}

        // ProgressBar: same track/fill styling convention as Slider, but
        // read-only (no drag interaction).
        Text `Profile completion` text-gray-700 text-sm font-medium pt-2
        ProgressBar w-full text-emerald-500 border-gray-200 {value: 82}

        Button `SAVE CHANGES` w-full text-center text-white font-semibold bg-blue-600 hover:bg-blue-700 hover:rotate-1 active:scale-95 py-3 rounded transition duration-150 ease-out m-[16px 0 0 0] {onClick: state.save}
      }

      // Scrollable log: `scroll-v` + a `border-blue-300` that both frames
      // the box AND tints its scrollbar thumb (no separate scrollbar-*
      // classes â€” the scrollbar reuses border-color, see CLAUDE.md).
      Card w-[fill] bg-white border border-gray-200 rounded-lg p-4 gap-2 {
        Text `Activity Log` text-gray-700 text-sm font-medium pb-1
        List scroll-v h-[160px] w-full border border-blue-300 rounded gap-1 p-2 {
          Text `User signed in` text-gray-600 text-sm
          Text `Settings updated` text-gray-600 text-sm
          Text `New device authorized` text-gray-600 text-sm
          Text `Password changed` text-gray-600 text-sm
          Text `Report generated` text-gray-600 text-sm
          Text `User signed out` text-gray-600 text-sm
          Text `Invoice #204 paid` text-gray-600 text-sm
        }
      }
    }

    // Opacity + 2D transform demo, independent of hover state.
    Container row w-[960px] gap-4 {
      Card w-[fill] bg-purple-500 text-white rounded-lg p-4 opacity-70 {
        Text `opacity-70` font-semibold
      }
      Card w-[fill] bg-emerald-500 text-white rounded-lg p-4 rotate-3 {
        Text `rotate-3` font-semibold
      }
      Card w-[fill] bg-amber-500 text-white rounded-lg p-4 scale-95 {
        Text `scale-95` font-semibold
      }
      Card w-[fill] bg-sky-500 text-white rounded-lg p-4 skew-x-3 {
        Text `skew-x-3` font-semibold
      }
    }
  }
}
